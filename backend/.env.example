# Server
PORT=3001
NODE_ENV=development

# Google Gemini — LLM (scene breakdown + shot list) + Image generation
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

# Gemini audio model (Lyria 3)
GEMINI_AUDIO_MODEL=lyria-3-clip-preview

# Timeouts (ms)
EXTERNAL_API_TIMEOUT=30000

# CORS allowed origin
FRONTEND_ORIGIN=http://localhost:5173

# AstraDB — Multimodal RAG vector store
# Get these from https://astra.datastax.com → your DB → Connect
ASTRA_DB_APPLICATION_TOKEN=AstraCS:...
ASTRA_DB_API_ENDPOINT=https://<db-id>-<region>.apps.astra.datastax.com
# Collection name (created automatically on first ingest)
ASTRA_DB_COLLECTION=media_assets
